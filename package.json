{
  "name": "zwep",
  "version": "0.1.0",
  "private": true,
  "description": "A small, self-hosted search engine — crawler + index + API.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*",
    "web"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "api": "node --experimental-strip-types services/api/src/server.ts",
    "crawl": "node --experimental-strip-types services/worker/src/cli.ts",
    "infra:up": "docker compose up -d meilisearch redis",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
