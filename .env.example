# Zwep environment
# Copy to .env and adjust.

# Meilisearch
MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=zwep_dev_master_key_change_me
MEILI_INDEX=zwep_documents

# Redis (queue) — optional in Phase 1 (crawler runs inline without it)
REDIS_URL=redis://127.0.0.1:6379

# API
API_PORT=8080
API_HOST=0.0.0.0
# Comma-separated allowed CORS origins ("*" for dev)
API_CORS_ORIGINS=*
# Admin/write key (x-zwep-key header)
ZWEP_ADMIN_KEY=zwep_admin_dev_key

# Crawler
CRAWLER_USER_AGENT=ZwepBot/1.0 (+https://zwep.example)
CRAWLER_CONCURRENCY=4
CRAWLER_DELAY_MS=500

# Google proxy (privacy — opt-in). When false, google-type sources are rejected.
# Enable only if you explicitly want Zwep to query Google on your behalf.
GOOGLE_PROXY_ENABLED=false
